# LinkedIn OAuth App credentials
# Create an app at https://www.linkedin.com/developers/apps
LI_CLIENT_ID=your_client_id_here
LI_CLIENT_SECRET=your_client_secret_here

# Must match exactly what you registered as the OAuth redirect URI in your LinkedIn app
LI_REDIRECT_URI=http://localhost:8000/callback

# Random secret used to sign entry tokens — change this to any long random string
APP_SECRET=change-me-to-something-random
